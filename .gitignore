# Dépendances PHP/MVC (jamais committées : MariaDB locale)
/php-mvc/uploads/
!/php-mvc/uploads/.gitkeep

# Environnement Emergent (interne à la plateforme, pas pour GitHub)
.emergent/
/memory/
/test_reports/
/tests/
test_result.md
.ruff_cache/

# Backend FastAPI proxy (utilisé par Emergent, inutile sur GitHub)
/backend/__pycache__/
*.pyc

# Frontend React initial (non utilisé pour ce portfolio statique)
/frontend/node_modules/
/frontend/.cache/

# Fichiers OS / éditeur
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Logs et bases locales
*.log
/var/

# Sauvegardes locales du portfolio (l'utilisateur exporte manuellement)
*.bak
portfolio-*.json.backup
